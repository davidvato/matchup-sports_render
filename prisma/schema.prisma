generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("ADMIN") // SUPERADMIN, ADMIN
  createdAt DateTime @default(now())
  tournaments Tournament[]
}

model Tournament {
  id          String   @id @default(cuid())
  name        String
  sport       String?
  createdAt   DateTime @default(now())
  creatorId   Int
  creator     User     @relation(fields: [creatorId], references: [id])
  groups      Group[]
}

model Group {
  id           String     @id @default(cuid())
  name         String
  tournamentId String
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches      Match[]
  pairs        Pair[]
}

model Pair {
  id           String   @id @default(cuid())
  name         String
  groupId      String
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  scores       Score[]
  totalScore   Int      @default(0)
  
  // Relations for matches
  matchesAsA   Match[]  @relation("PairAMatches")
  matchesAsB   Match[]  @relation("PairBMatches")

  @@unique([groupId, name])
}

model Match {
  id        String   @id @default(cuid())
  groupId   String
  pairAId   String
  pairBId   String
  winnerId  String?
  pointsA   Int      @default(0)
  pointsB   Int      @default(0)
  createdAt DateTime @default(now())
  pairB     Pair     @relation("PairBMatches", fields: [pairBId], references: [id], onDelete: Cascade)
  pairA     Pair     @relation("PairAMatches", fields: [pairAId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, pairAId, pairBId])
}

model Score {
  id        String   @id @default(cuid())
  points    Int
  pairId    String
  createdAt DateTime @default(now())
  pair      Pair     @relation(fields: [pairId], references: [id], onDelete: Cascade)
}
