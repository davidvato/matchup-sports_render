generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("ADMIN") // SUPERADMIN, ADMIN
  createdAt DateTime @default(now())
  tournaments Tournament[]
}

model Tournament {
  id          String   @id @default(cuid())
  name        String
  location    String?
  startDate   DateTime?
  endDate     DateTime?
  sport       String?
  description String?
  createdAt   DateTime @default(now())
  creatorId   Int
  creator     User     @relation(fields: [creatorId], references: [id])
  categories  Category[]
}

model Category {
  id           String     @id @default(cuid())
  name         String
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  groups       Group[]
  brackets     Bracket[]
  pairs        Pair[]
  createdAt    DateTime   @default(now())
}

model Group {
  id           String     @id @default(cuid())
  name         String
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  matches      Match[]
  pairs        Pair[]
  createdAt    DateTime   @default(now())
}

model Bracket {
  id           String     @id @default(cuid())
  name         String
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  matches      BracketMatch[]
  createdAt    DateTime   @default(now())
}

model Pair {
  id           String   @id @default(cuid())
  name         String
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  groupId      String?
  group        Group?    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  scores       Score[]
  totalScore   Int      @default(0)
  
  // Relations for matches
  matchesAsA   Match[]  @relation("PairAMatches")
  matchesAsB   Match[]  @relation("PairBMatches")
  
  bracketMatchesAsA BracketMatch[] @relation("BPairAMatches")
  bracketMatchesAsB BracketMatch[] @relation("BPairBMatches")

  matchesAsA2  Match[] @relation("PairA2Matches")
  matchesAsB2  Match[] @relation("PairB2Matches")

  @@unique([categoryId, name])
}

model Match {
  id        String   @id @default(cuid())
  groupId   String
  pairAId   String
  pairBId   String?
  pairA2Id  String?
  pairB2Id  String?
  winnerId  String?
  pointsA   Int      @default(0)
  pointsB   Int      @default(0)
  set1A     Int      @default(0)
  set1B     Int      @default(0)
  set2A     Int      @default(0)
  set2B     Int      @default(0)
  set3A     Int      @default(0)
  set3B     Int      @default(0)
  set4A     Int      @default(0)
  set4B     Int      @default(0)
  set5A     Int      @default(0)
  set5B     Int      @default(0)
  createdAt DateTime @default(now())
  pairB     Pair?    @relation("PairBMatches", fields: [pairBId], references: [id], onDelete: Cascade)
  pairA     Pair     @relation("PairAMatches", fields: [pairAId], references: [id], onDelete: Cascade)
  pairA2    Pair?    @relation("PairA2Matches", fields: [pairA2Id], references: [id])
  pairB2    Pair?    @relation("PairB2Matches", fields: [pairB2Id], references: [id])
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model BracketMatch {
  id          String   @id @default(cuid())
  bracketId   String
  bracket     Bracket  @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  round       Int      // 1: Final, 2: Semis, 4: Quarters, etc.
  matchIndex  Int      // Position in the round
  pairAId     String?
  pairBId     String?
  winnerId    String?
  pointsA     Int      @default(0)
  pointsB     Int      @default(0)
  set1A       Int      @default(0)
  set1B       Int      @default(0)
  set2A       Int      @default(0)
  set2B       Int      @default(0)
  set3A       Int      @default(0)
  set3B       Int      @default(0)
  set4A       Int      @default(0)
  set4B       Int      @default(0)
  set5A       Int      @default(0)
  set5B       Int      @default(0)
  createdAt   DateTime @default(now())
  
  pairA       Pair?    @relation("BPairAMatches", fields: [pairAId], references: [id])
  pairB       Pair?    @relation("BPairBMatches", fields: [pairBId], references: [id])
  
  nextMatchId String?  // ID of the match the winner goes to
}

model Score {
  id        String   @id @default(cuid())
  points    Int
  pairId    String
  createdAt DateTime @default(now())
  pair      Pair     @relation(fields: [pairId], references: [id], onDelete: Cascade)
}
